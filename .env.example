# ── Sistema ─────────────────────────────────────────────────────────────────
# UID/GID do usuário no host (rode: id -u && id -g)
PUID=1000
PGID=1000

# Fuso horário
TZ=America/Sao_Paulo

# ── Plex ────────────────────────────────────────────────────────────────────
# Token de claim: pegue em https://www.plex.tv/claim/ (expira em 4 minutos)
# Necessário apenas no primeiro boot para vincular ao seu conta Plex
PLEX_CLAIM=claim-XXXXXXXXXXXXXXXX
